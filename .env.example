# ============================================================
# Agent 00A - Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Google Drive ---
# The folder ID to poll for new Loom recordings.
# Find this in the Google Drive URL: https://drive.google.com/drive/folders/<THIS_ID>
GOOGLE_DRIVE_FOLDER_ID=REPLACE_ME

# Service Account credentials (preferred).
# Paste the entire JSON key file content as a single line, or set the path.
# Option A: JSON string (for Vercel / env var)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: Path to key file (for local dev)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json

# --- OpenAI ---
OPENAI_API_KEY=sk-...your-openai-api-key

# --- Worker Config (optional) ---
# Max retries before moving event to dead_letters (default: 3)
MAX_RETRIES=3
# Poll interval in milliseconds (default: 60000 = 60s)
POLL_INTERVAL_MS=60000
# Max file size in bytes for transcription (default: 209715200 = 200MB)
MAX_FILE_SIZE_BYTES=209715200
