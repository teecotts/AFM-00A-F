{
  "crons": [
    {
      "path": "/api/poll-drive",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/run-worker",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/run-content-writer",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "api/poll-drive.ts": {
      "maxDuration": 30
    },
    "api/run-worker.ts": {
      "maxDuration": 120
    },
    "api/run-content-writer.ts": {
      "maxDuration": 120
    },
    "api/review.ts": {
      "maxDuration": 10
    },
    "api/review/update.ts": {
      "maxDuration": 10
    },
    "api/review/bulk-approve.ts": {
      "maxDuration": 10
    }
  }
}
